# Copia este archivo a `.env` (NO comitearlo) para desarrollo local.

# URL de la base de datos. Por defecto: SQLite local en ./hotel.db
# Para Postgres en Railway descomenta y usa la URL que provee Railway:
# HOTEL_DB_URL=postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DBNAME
HOTEL_DB_URL=sqlite:///./hotel.db

# Si está en "1", el seed sólo corre cuando la tabla habitaciones está vacía.
SEED_ONLY_IF_EMPTY=0

# Puerto local
PORT=8000
